#!/bin/bash
# Pre-push hook: Lightweight validation before push
# Only scans files changed on the current branch (vs origin/main or origin/HEAD).
# Full CI runs on merge to main — this just catches obvious issues fast.

set -e

echo "Running pre-push checks..."

# Determine project root
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Handle both hooks/ source dir and .git/hooks/ installed location
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "$PROJECT_ROOT")"
if [ ! -f "$PROJECT_ROOT/scripts/check-strings.sh" ] && [ -f "$GIT_ROOT/scripts/check-strings.sh" ]; then
    PROJECT_ROOT="$GIT_ROOT"
fi

# Find changed Dart files on this branch vs the merge base
BASE_BRANCH="origin/main"
if ! git rev-parse --verify "$BASE_BRANCH" &>/dev/null; then
    BASE_BRANCH="origin/HEAD"
fi
MERGE_BASE=$(git merge-base HEAD "$BASE_BRANCH" 2>/dev/null || echo "HEAD~10")
CHANGED_DART=$(git diff --name-only --diff-filter=ACM "$MERGE_BASE"..HEAD -- '*.dart' 2>/dev/null || true)

if [ -z "$CHANGED_DART" ]; then
    echo "No Dart files changed on this branch. Skipping checks."
    echo "Pre-push checks passed."
    exit 0
fi

CHANGED_COUNT=$(echo "$CHANGED_DART" | wc -l | tr -d ' ')
echo "Scanning $CHANGED_COUNT changed Dart file(s)..."

# Step 1: String literal safety on changed files only
if [ -f "$PROJECT_ROOT/scripts/check-strings.sh" ]; then
    echo ""
    echo "Step 1: String literal safety..."
    # check-strings.sh scans lib/ by default; pass --staged for minimal scope
    bash "$PROJECT_ROOT/scripts/check-strings.sh" --staged 2>/dev/null || \
        bash "$PROJECT_ROOT/scripts/check-strings.sh"
fi

# Step 2: Lightweight lint on changed files only
if [ -f "$PROJECT_ROOT/scripts/lint-noflutter.sh" ]; then
    echo ""
    echo "Step 2: Lightweight lint..."
    # shellcheck disable=SC2086
    bash "$PROJECT_ROOT/scripts/lint-noflutter.sh" $CHANGED_DART
fi

echo ""
echo "Pre-push checks passed. CI will run full validation on merge to main."
